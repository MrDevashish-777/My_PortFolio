---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import CustomCursor from "@/components/CustomCursor";
import PageTransition, { ScrollProgress } from "@/components/PageTransition";
import GoUpButton from "@/components/GoUpButton";
import { siteConfig } from "@/data/config";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteConfig.url).toString();

const resolvedImageWithDomain = new URL(
  "/Myself_Ai.jpeg",
  Astro.site || siteConfig.url
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? `${title} | ${siteConfig.name}`
  : `${siteConfig.name} - ${siteConfig.title}`;
---

<!doctype html>
<html lang="en" className="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={siteConfig.description}
      canonical={canonicalURL}
      twitter={{
        creator: siteConfig.twitter,
        site: siteConfig.twitter,
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `${siteConfig.name} - ${siteConfig.title}`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: `${siteConfig.name} Portfolio`,
        },
      }}
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": siteConfig.name,
      "url": siteConfig.url,
      "jobTitle": siteConfig.title,
      "sameAs": [
        siteConfig.github,
        siteConfig.linkedin
      ]
    })} />
  </head>
  <body className="antialiased selection:bg-indigo-500/30 selection:text-indigo-900 dark:selection:text-indigo-100">
    <CustomCursor client:load />
    
    <!-- Scroll Progress Indicator -->
    <ScrollProgress client:load />
    
    <Navbar />
    
    <PageTransition client:load>
      <slot />
    </PageTransition>
    
    <Footer />
    
    <GoUpButton client:load />

    <style is:global>
      /* Improve Page speed */
      img {
        content-visibility: auto;
      }
    </style>
    <SpeedInsights />
    <Analytics />
  </body>
</html>
