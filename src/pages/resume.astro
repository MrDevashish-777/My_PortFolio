---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Resume">
  <section class="py-20">
    <Container>
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold">Resume</h1>
        <p class="text-slate-600 mt-3">Download or preview my resume below.</p>
      </div>

      <div class="max-w-4xl mx-auto bg-white/80 dark:bg-slate-800 rounded-2xl p-6 shadow-lg">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h2 class="text-lg font-semibold">T. Devashish Pillay</h2>
            <p class="text-sm text-slate-500">B.Tech CSE — SBJITMR, Nagpur</p>
          </div>
          <div className="flex items-center gap-3">
            <a href="/Devashish_Pillay_Resume.pdf" download class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-indigo-500 to-indigo-600 hover:from-indigo-600 hover:to-indigo-700 text-white rounded-lg transition-colors shadow-sm">Download PDF</a>
            <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors">Contact</a>
          </div>
        </div>

        <div class="border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden" style="height:800px;">
          <iframe src="/Devashish_Pillay_Resume.pdf" width="100%" height="100%" class="min-h-[600px]" aria-label="Resume PDF preview"></iframe>
        </div>

        <p class="text-sm text-slate-500 mt-3">If the preview does not load, place your resume PDF at the project `public/Devashish_Pillay_Resume.pdf` path.</p>
      </div>
    </Container>
  </section>
</Layout>
